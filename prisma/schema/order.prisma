model Order {
    id         String @id @default(cuid())
    customerId String
    customer   User   @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Restrict)

    menuItemId String
    menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

    paymentId String?
    payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

    status                  OrderStatus @default(PENDING)
    quantity                Int         @default(1)
    totalCents              Int
    notes                   String?
    deliveryAddressSnapshot Json? // store address snapshot at time of order

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([customerId])
    @@index([restaurantId])
    @@index([menuItemId])
    @@index([paymentId])
}

enum OrderStatus {
    PENDING
    CONFIRMED
    PREPARING
    OUT_FOR_DELIVERY
    DELIVERED
    CANCELLED
}
